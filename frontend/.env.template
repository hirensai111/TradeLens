# TradeLens Frontend Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ========================
# API ENDPOINTS
# ========================

# Main API Server URL
REACT_APP_API_URL=http://localhost:5000

# AI Assistant API URL
REACT_APP_AI_API_URL=http://localhost:5001

# ========================
# DEPLOYMENT SETTINGS
# ========================

# Environment (development, staging, production)
NODE_ENV=development

# Public URL for the application (used in builds)
PUBLIC_URL=

# ========================
# OPTIONAL SETTINGS
# ========================

# Enable/disable source maps in production
GENERATE_SOURCEMAP=false

# Browser to open when starting dev server
BROWSER=default

# Port for development server (default: 3000)
PORT=3001

# ========================
# EXAMPLE PRODUCTION VALUES
# ========================

# For production deployment, use these instead:
# REACT_APP_API_URL=https://api.tradelens.com
# REACT_APP_AI_API_URL=https://ai.tradelens.com
# NODE_ENV=production
# GENERATE_SOURCEMAP=false